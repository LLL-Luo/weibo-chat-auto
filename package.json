{
  "name": "weibo-group-chat-archiver",
  "version": "1.0.0",
  "description": "Weibo Group Chat Archiver - 微博群聊消息自动归档工具",
  "main": "auto-archive-simple.js",
  "scripts": {
    "save-cookies": "node save-cookies.js",
    "archive": "node auto-archive-simple.js",
    "clean": "node -e \"const fs=require('fs'),p=require('path');const d='output';fs.readdirSync(d).filter(f=>/T\\d{2}-/.test(f)).forEach(f=>{console.log('Remove:',f);fs.unlinkSync(p.join(d,f))})\"",
    "start-chrome": "./start-chrome.sh",
    "view": "node viewer-server.js"
  },
  "keywords": ["weibo", "chat", "archive"],
  "author": "allo",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "puppeteer": "^24.43.0"
  }
}
