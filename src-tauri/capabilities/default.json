{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:3456/*"]
  },
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "viewer-server", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "viewer-server", "sidecar": true, "args": true }
      ]
    },
    "shell:allow-kill",
    "shell:default"
  ]
}
